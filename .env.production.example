# CareerWave production environment template
# Copy these into Vercel Project Settings -> Environment Variables.

NODE_ENV="production"
NEXT_PUBLIC_APP_NAME="CareerWave"
NEXT_PUBLIC_APP_URL="https://careerwave.eu"
NEXT_PUBLIC_APP_DOMAIN="careerwave.eu"

# PostgreSQL / Prisma
# For Neon/Supabase/serverless Postgres, DATABASE_URL should usually be the pooled/runtime URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional direct URL for migrations/schema operations if your provider gives one.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth
JWT_ACCESS_SECRET="replace-with-a-random-64-character-secret"
JWT_REFRESH_SECRET="replace-with-another-random-64-character-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# JWT verification metadata
JWT_ISSUER="careerwave.eu"
JWT_AUDIENCE="careerwave-web"

# Uploads
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB="5"

# Rate limiting
AUTH_RATE_LIMIT_MAX="10"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
WRITE_RATE_LIMIT_MAX="60"
WRITE_RATE_LIMIT_WINDOW_MS="60000"

# File storage: "auto", "local", or "vercel-blob". Use local for development and vercel-blob on Vercel.
FILE_STORAGE_DRIVER="auto"
# Required only when FILE_STORAGE_DRIVER="vercel-blob", or when deploying to Vercel with auto mode.
BLOB_READ_WRITE_TOKEN=""
