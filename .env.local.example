DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerwave?schema=public"
NEXT_PUBLIC_APP_NAME="CareerWave"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="careerwave.eu"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
UPLOAD_DIR="public/uploads"
MAX_UPLOAD_MB="5"
JWT_ISSUER="careerwave.eu"
JWT_AUDIENCE="careerwave-web"
AUTH_RATE_LIMIT_MAX="10"
AUTH_RATE_LIMIT_WINDOW_MS="60000"
WRITE_RATE_LIMIT_MAX="60"
WRITE_RATE_LIMIT_WINDOW_MS="60000"

# File storage: "auto", "local", or "vercel-blob". Use local for development and vercel-blob on Vercel.
FILE_STORAGE_DRIVER="auto"
# Required only when FILE_STORAGE_DRIVER="vercel-blob", or when deploying to Vercel with auto mode.
BLOB_READ_WRITE_TOKEN=""
